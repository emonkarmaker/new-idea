# Audio Settings (Optional - defaults are in the script)
# SAMPLE_RATE=16000
# CHANNELS=1
# ENERGY_THRESHOLD=0.03
# SILENCE_DURATION=0.8

# Application Settings (Optional)
# MIN_SPEECH_DURATION=1.0
# MAX_SPEECH_DURATION=10.0
